# Canal de Denúncia Online — .env.example
# Copie para .env e preencha. Nunca commitar .env.

# IP público da VPS. Usado pelo smoke-test para validar exposição externa.
VPS_IP=

# Domínio do portal na VPS.
DOMAIN_PORTAL=denuncia.canaldenunciaonline.com.br

# E-mail usado pelo Traefik para Let's Encrypt.
LETSENCRYPT_EMAIL=

# PostgreSQL
POSTGRES_DB=canal_denuncia
POSTGRES_USER=canal_user
# Gerar com: openssl rand -base64 32
POSTGRES_PASSWORD=

# Redis
# Gerar com: openssl rand -base64 32
REDIS_PASSWORD=

# SMTP Brevo
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=
BREVO_SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Canal de Denúncia Online

# hCaptcha
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET=

# Backblaze B2
BACKBLAZE_BUCKET=
BACKBLAZE_KEY_ID=
BACKBLAZE_APP_KEY=

# Backup
BACKUP_RETENTION_LOCAL_DAYS=7
BACKUP_RETENTION_OFFSITE_DAYS=30
# Se true, backup.sh falha quando BACKUP_ENCRYPTION_PASSPHRASE estiver vazia.
BACKUP_REQUIRE_ENCRYPTION=true
# Gerar com: openssl rand -base64 48
BACKUP_ENCRYPTION_PASSPHRASE=

# Observabilidade futura
SENTRY_DSN=
